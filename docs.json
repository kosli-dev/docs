{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Kosli Documentation",
  "colors": {
    "primary": "#1C4BC6",
    "light": "#ABBDFF",
    "dark": "#1C4BC6"
  },
  "fonts": {
    "family": "IBM Plex Sans"
  },
  "api": {
    "playground": {
      "display": "interactive"
    }
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": {
      "theme": "dracula",
      "languages": {
        "custom": [
          "/languages/rego.json"
        ]
      }
    }
  },
  "background": {
    "decoration": "windows",
    "color": {
      "dark": "#111A26",
      "light": "#F6F8FC"
    }
  },
  "metadata": {
    "timestamp": true
  },
  "favicon": "/favicon-32x32.png",
  "redirects": {
    "$ref": "./config/redirects.json"
  },
  "navigation": {
    "$ref": "./config/navigation.json"
  },
  "logo": {
    "light": "/logo/kosli-logo-light-main.svg",
    "dark": "/logo/kosli-logo-dark-main.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@kosli.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Kosli App",
      "href": "https://app.kosli.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "$ref": "./config/footer.json"
  }
}
